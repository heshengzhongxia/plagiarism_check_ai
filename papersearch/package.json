{
  "name": "papersearch-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5001 && electron .",
    "dev:full": "concurrently \"python app.py\" \"npm run dev:react\"",
    "build:react": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"var fs=require('fs');['main','preload','python-manager'].forEach(function(f){fs.renameSync('dist-electron/'+f+'.js','dist-electron/'+f+'.cjs')})\" && node -e \"var fs=require('fs');var c=fs.readFileSync('dist-electron/main.cjs','utf8');c=c.replace('require(\\\"./python-manager\\\")','require(\\\"./python-manager.cjs\\\")');c=c.replace(\\\"'preload.js'\\\",\\\"'preload.cjs'\\\");fs.writeFileSync('dist-electron/main.cjs',c)\"",
    "build:full": "npm run build:react && npm run build:electron",
    "dist": "npm run build:full && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
